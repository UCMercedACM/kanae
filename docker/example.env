# The location of where Kanae's configuration is stored.
# The configuration can be found under the config.dist.yml
# Note that this must be an absolute path to the config file
CONFIG_LOCATION=./config.yml

# Connection secret for the postgres user. You should change it to a random password
DB_PASSWORD=password

# Per-hook webhook tokens for Kratos -> Kanae callbacks. Each value is
# blake3.keyed_hash(context_label, key=KANAE_WEBHOOK_MASTER) hex-encoded,
# where KANAE_WEBHOOK_MASTER is the master secret in Kanae's config.yml.
#
# Generate Kanae's master with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Then derive each token with:
#   python -c "import blake3; print(blake3.blake3(b'kratos.<hook>.v1', \
#       key=bytes.fromhex('<master>')).hexdigest())"
KRATOS_WEBHOOK_TOKEN_REGISTRATION=ac3b6f86ef45d732411258e52b29a7ea896065de5b3e26ea47c3f449e2189a41
KRATOS_WEBHOOK_TOKEN_SETTINGS=e666f6bdf31a9be3ccfda64d0a268a4324dd9a74d427f49fcac24126a2096749

# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=kanae
