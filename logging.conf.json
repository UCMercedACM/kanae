{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "default": {
            "()": "uvicorn.logging.DefaultFormatter",
            "fmt": "[%(asctime)s] %(levelprefix)s %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S",
            "use_colors": true
        },
        "access": {
            "()": "uvicorn.logging.AccessFormatter",
            "fmt": "[%(asctime)s] %(levelprefix)s %(client_addr)s - \"%(request_line)s\" %(status_code)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "default": {
            "formatter": "default",
            "class": "logging.StreamHandler",
            "stream": "ext://sys.stderr"
        },
        "access": {
            "formatter": "access",
            "class": "logging.StreamHandler",
            "stream": "ext://sys.stdout"
        },
        "rotating": {
            "()": "core.rotating_handler",
            "formatter": "default"
        }
    },
    "loggers": {
        "uvicorn": {
            "handlers": ["default", "rotating"],
            "level": "INFO",
            "propagate": false
        },
        "uvicorn.error": {
            "level": "INFO"
        },
        "uvicorn.access": {
            "handlers": ["access", "rotating"],
            "level": "INFO",
            "propagate": false
        },
        "kanae": {
            "handlers": ["default", "rotating"],
            "level": "INFO",
            "propagate": false
        },
        "kanae.error": {
            "level": "ERROR"
        },
        "kanae.ory": {
            "level": "DEBUG",
            "propagate": false
        },
        "kanae.limiter": {
            "level": "DEBUG",
            "propagate": false
        }
    }
}